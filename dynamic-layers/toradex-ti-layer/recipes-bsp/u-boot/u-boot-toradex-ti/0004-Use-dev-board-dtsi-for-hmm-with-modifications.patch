From 34dcb1f87d95fa6e3f1367d9ff37f481e8cd349d Mon Sep 17 00:00:00 2001
From: rikardo <rikard.olander@hostmobility.com>
Date: Wed, 29 Jan 2025 13:44:12 +0000
Subject: [PATCH 4/4] Use-dev-board-dtsi-for-hmm-with-modifications

---
 arch/arm/dts/k3-am62-verdin-dev.dtsi          | 114 +++++++-----------
 arch/arm/dts/k3-am62-verdin.dtsi              |  56 +++++++--
 .../dts/k3-am625-verdin-wifi-dev-u-boot.dtsi  |  77 ++++++++++--
 3 files changed, 157 insertions(+), 90 deletions(-)

diff --git a/arch/arm/dts/k3-am62-verdin-dev.dtsi b/arch/arm/dts/k3-am62-verdin-dev.dtsi
index 6701cb8974b..dee8287c1b9 100644
--- a/arch/arm/dts/k3-am62-verdin-dev.dtsi
+++ b/arch/arm/dts/k3-am62-verdin-dev.dtsi
@@ -47,23 +47,13 @@
 /* Verdin ETHs */
 &cpsw3g {
 	pinctrl-names = "default";
-	pinctrl-0 = <&pinctrl_rgmii1>, <&pinctrl_rgmii2>;
+	pinctrl-0 = <&pinctrl_rgmii1>;
 	status = "okay";
 };
 
 /* MDIO, shared by Verdin ETH_1 (On-module PHY) and Verdin ETH_2_RGMII */
 &cpsw3g_mdio {
 	status = "okay";
-
-	cpsw3g_phy1: ethernet-phy@7 {
-		compatible = "ethernet-phy-ieee802.3-c22";
-		reg = <7>;
-		interrupt-parent = <&main_gpio0>;
-		interrupts = <38 IRQ_TYPE_EDGE_FALLING>;
-		pinctrl-names = "default";
-		pinctrl-0 = <&pinctrl_eth2_rgmii_int>;
-		micrel,led-mode = <0>;
-	};
 };
 
 /* Verdin ETH_1 (On-module PHY) */
@@ -71,32 +61,6 @@
 	status = "okay";
 };
 
-/* Verdin ETH_2_RGMII */
-&cpsw_port2 {
-	phy-handle = <&cpsw3g_phy1>;
-	phy-mode = "rgmii-rxid";
-	status = "okay";
-};
-
-/* Verdin PWM_1, PWM_2 */
-&epwm0 {
-	status = "okay";
-};
-
-/* Verdin PWM_3_DSI */
-&epwm1 {
-	status = "okay";
-};
-
-&main_gpio0 {
-	pinctrl-names = "default";
-	pinctrl-0 = <&pinctrl_ctrl_sleep_moci>,
-		    <&pinctrl_gpio_5>,
-		    <&pinctrl_gpio_6>,
-		    <&pinctrl_gpio_7>,
-		    <&pinctrl_gpio_8>;
-};
-
 /* Verdin I2C_1 */
 &main_i2c1 {
 	status = "okay";
@@ -111,42 +75,52 @@
 	};
 
 	/* IO Expander */
-	gpio_expander_21: gpio@21 {
-		compatible = "nxp,pcal6416";
-		reg = <0x21>;
-		#gpio-cells = <2>;
+	max7321: gpio-expander@68 {
+		compatible = "maxim,max7320";
+		reg = <0x68>;
 		gpio-controller;
+		#gpio-cells = <2>;
+		gpio-line-names =
+				"green_led_2", "red_led_2",
+				"green_led_1", "red_led_1",
+				"green_led_4", "red_led_4",
+				"green_led_3", "red_led_3";
+		interrupt-controller;
+		#interrupt-cells = <2>;
 	};
 
-	/* Current measurement into module VCC */
-	hwmon@40 {
-		compatible = "ti,ina219";
-		reg = <0x40>;
-		shunt-resistor = <10000>;
+	/*USB-C controller*/
+	typec@1d {
+		compatible = "nxp,ptn5150";
+		pinctrl-names = "default";
+		pinctrl-0 = <&pinctrl_usb1_irq>;
+		interrupt-parent = <&main_gpio0>;
+		interrupts = <38 IRQ_TYPE_LEVEL_HIGH>;
+		reg = <0x1d>;
+		status ="okay";
 	};
 
-	/* Temperature sensor */
-	sensor@4f {
-		compatible = "ti,tmp75c";
-		reg = <0x4f>;
+	eeprom@54 {
+		compatible = "st,24c02", "atmel,24c04";
+		reg = <0x54>;
+		status = "okay";
+		//vcc-supply = <&reg_base_3v3>;
 	};
 
-	/* EEPROM */
-	eeprom@57 {
-		compatible = "st,24c02", "atmel,24c02";
-		reg = <0x57>;
-		pagesize = <16>;
+	/* HW confirmed, TMP103D has address 0x73 */
+	temperature-sensor@73 {
+		compatible = "ti,tmp103";
+		reg = <0x73>;
+		status = "disable";
 	};
-};
-
-/* Verdin I2C_2_DSI */
-&main_i2c2 {
-	status = "okay";
-};
-
-/* Verdin I2C_4_CSI */
-&main_i2c3 {
-	status = "okay";
+	/*
+	Add HSM module
+	hsm@48 {
+		compatible = "There is no driver";
+		reg = <0x48>;
+		status = "okay";
+	};
+	*/
 };
 
 /* Verdin CAN_1 */
@@ -199,11 +173,6 @@
 	status = "okay";
 };
 
-/* Verdin QSPI_1 */
-&ospi0 {
-	status = "okay";
-};
-
 /* Verdin SD_1 */
 &sdhci1 {
 	ti,driver-strength-ohm = <33>;
@@ -217,15 +186,16 @@
 
 &usb0 {
 	status = "okay";
+	dr_mode = "otg";
 };
 
 /* Verdin USB_2 */
 &usbss1 {
-	status = "okay";
+	status = "okay"; // "disabled";
 };
 
 &usb1 {
-	status = "okay";
+	status = "okay"; // "disabled";
 };
 
 /* Verdin CTRL_WAKE1_MICO# */
diff --git a/arch/arm/dts/k3-am62-verdin.dtsi b/arch/arm/dts/k3-am62-verdin.dtsi
index d4f8776c927..8e20b1ce4be 100644
--- a/arch/arm/dts/k3-am62-verdin.dtsi
+++ b/arch/arm/dts/k3-am62-verdin.dtsi
@@ -41,7 +41,21 @@
 		usb0 = &usb0;
 		usb1 = &usb1;
 	};
-
+	connector {
+		compatible = "gpio-usb-b-connector", "usb-b-connector";
+		pinctrl-names = "default";
+		pinctrl-0 = <&pinctrl_usb0_id>;
+		id-gpios = <&main_gpio1 19 GPIO_ACTIVE_HIGH>;
+		label = "USB_1";
+		self-powered;
+		vbus-supply = <&reg_usb0_vbus>;
+
+		port {
+			usb_dr_connector: endpoint {
+				remote-endpoint = <&usb0_ep>;
+			};
+		};
+	};
 	verdin_gpio_keys: gpio-keys {
 		compatible = "gpio-keys";
 		pinctrl-names = "default";
@@ -151,6 +165,18 @@
 		vin-supply = <&reg_sd_3v3_1v8>;
 	};
 
+	reg_usb0_vbus: regulator-usb0-vbus {
+		compatible = "regulator-fixed";
+		pinctrl-names = "default";
+		pinctrl-0 = <&pinctrl_usb0_en>;
+		enable-active-high;
+		/* Verdin USB_1_EN (SODIMM 155) */
+		gpio = <&main_gpio1 50 GPIO_ACTIVE_HIGH>;
+		regulator-max-microvolt = <5000000>;
+		regulator-min-microvolt = <5000000>;
+		regulator-name = "USB_1_EN";
+	};
+
 	reserved-memory {
 		#address-cells = <2>;
 		#size-cells = <2>;
@@ -647,10 +673,10 @@
 		>;
 	};
 
-	/* Verdin USB_1 */
-	pinctrl_usb0: main-usb0-default-pins {
+	/* Verdin USB_1_EN */
+	pinctrl_usb0_en: main-gpio1-50-default-pins {
 		pinctrl-single,pins = <
-			AM62X_IOPAD(0x0254, PIN_OUTPUT, 0) /* (C20) USB0_DRVVBUS */ /* SODIMM 155 */
+			AM62X_IOPAD(0x0254, PIN_INPUT, 7) /* (C20) USB0_DRVVBUS.GPIO1_50 */ /* SODIMM 155 */
 		>;
 	};
 
@@ -688,6 +714,11 @@
 			AM62X_IOPAD(0x0060, PIN_OUTPUT, 1) /*  (R25) GPMC0_AD9.VOUT0_DATA17 */
 		>;
 	};
+	pinctrl_usb1_irq: usb1-irq-pins-default {
+		pinctrl-single,pins = <
+			AM62X_IOPAD(0x009c, PIN_INPUT, 7) /* (V25) GPMC0_WAIT1.GPIO0_38 */ /* GPIO_SODIMM_189 */
+		>;
+	};
 };
 
 &mcu_pmx0 {
@@ -901,7 +932,7 @@
 		"",
 		"",
 		"",
-		"", /* 50 */
+		"SODIMM 155", /* 50 */
 		"",
 		"",
 		"",
@@ -1412,14 +1443,21 @@
 /* Verdin USB_1 */
 &usbss0 {
 	ti,vbus-divider;
-	status = "disabled";
+	status = "okay";
 };
 
 /* TODO: role swich using ID pin */
 &usb0 {
-	pinctrl-names = "default";
-	pinctrl-0 = <&pinctrl_usb0>, <&pinctrl_usb0_id>;
-	status = "disabled";
+	adp-disable;
+   usb-role-switch;
+
+	status = "okay";
+
+	port {
+		usb0_ep: endpoint {
+			remote-endpoint = <&usb_dr_connector>;
+		};
+	};
 };
 
 /* Verdin USB_2 */
diff --git a/arch/arm/dts/k3-am625-verdin-wifi-dev-u-boot.dtsi b/arch/arm/dts/k3-am625-verdin-wifi-dev-u-boot.dtsi
index 206df610461..23ae8142337 100644
--- a/arch/arm/dts/k3-am625-verdin-wifi-dev-u-boot.dtsi
+++ b/arch/arm/dts/k3-am625-verdin-wifi-dev-u-boot.dtsi
@@ -8,7 +8,7 @@
 / {
 	aliases {
 		eeprom0 = &eeprom_module;
-		eeprom1 = &eeprom_carrier_board;
+		eeprom1 = &eeprom_hmm_board;
 		eeprom2 = &eeprom_display_adapter;
 	};
 
@@ -23,6 +23,71 @@
 	sysinfo {
 		compatible = "toradex,sysinfo";
 	};
+	/*	The leds is read from the highest to lowest position on the module when the pcb is in horizontal position.
+		Default: leds lit on the two lowest green/red LED (3 and 4) and the rest is off.
+	*/
+	leds {
+		compatible = "gpio-leds";
+
+		green_led_1 {
+			label = "green:led_1";
+			function = "led_1";
+			gpios = <&max7321 2 GPIO_ACTIVE_LOW>;
+			default-state = "off";
+		};
+
+		red_led_1 {
+			label = "red:led_1";
+			function = "led_1";
+			gpios = <&max7321 3 GPIO_ACTIVE_LOW>;
+			default-state = "off";
+		};
+
+		green_led_2 {
+			label = "green:led_2";
+			function = "led_2";
+			gpios = <&max7321 0 GPIO_ACTIVE_LOW>;
+			default-state = "off";
+		};
+
+		red_led_2 {
+			label = "red:led_2";
+			function = "led_2";
+			gpios = <&max7321 1 GPIO_ACTIVE_LOW>;
+			default-state = "off";
+		};
+
+		green_led_3 {
+			label = "green:led_3";
+			function = "led_3";
+			gpios = <&max7321 6 GPIO_ACTIVE_LOW>;
+			default-state = "on";
+		};
+
+		red_led_3 {
+			label = "red:led_1";
+			function = "led_3";
+			gpios = <&max7321 7 GPIO_ACTIVE_LOW>;
+			default-state = "on";
+		};
+
+		green_led_4 {
+			label = "green:led_4";
+			function = "led_4";
+			gpios = <&max7321 4 GPIO_ACTIVE_LOW>;
+			default-state = "on";
+		};
+
+		red_led_4 {
+			label = "red:led_4";
+			function = "led_4";
+			gpios = <&max7321 5 GPIO_ACTIVE_LOW>;
+			default-state = "on";
+		};
+
+
+	};
+
 };
 
 &main_timer0 {
@@ -82,9 +147,6 @@
 	bootph-all;
 };
 
-&cpsw3g_phy1 {
-	bootph-all;
-};
 
 &cpsw_port1 {
 	bootph-all;
@@ -127,12 +189,9 @@
 		reg = <0x50>;
 		pagesize = <16>;
 	};
-
-	/* EEPROM on carrier board */
-	eeprom_carrier_board: eeprom@57 {
+	eeprom_hmm_board: eeprom@54 {
 		compatible = "i2c-eeprom";
-		reg = <0x57>;
-		pagesize = <16>;
+		reg = <0x54>;
 	};
 };
 
